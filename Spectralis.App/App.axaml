<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:app="using:Spectralis.App"
             x:Class="Spectralis.App.App"
             RequestedThemeVariant="Dark">

  <Application.DataTemplates>
    <app:ViewLocator />
  </Application.DataTemplates>

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="/Design/Tokens.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Application.Resources>

  <Application.Styles>
    <!-- SimpleTheme supplies functional control templates only; all visual
         decisions are overridden by the token-driven styles in Design/. -->
    <SimpleTheme />
    <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Simple.xaml" />
    <StyleInclude Source="/Design/Controls.axaml" />
  </Application.Styles>

</Application>
