<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Spectralis.App.Controls.SessionHistoryPanel"
             Background="#0D0D0D">

  <Grid RowDefinitions="Auto, *">

    <TextBlock Grid.Row="0"
               Text="Session History"
               FontSize="14"
               Foreground="#888"
               Margin="16,12" />

    <ListBox Grid.Row="1"
             x:Name="SessionList"
             Background="Transparent"
             BorderThickness="0">
      <ListBox.ItemTemplate>
        <DataTemplate>
          <Grid ColumnDefinitions="*, Auto" Margin="12,8">
            <StackPanel Grid.Column="0" Spacing="2">
              <TextBlock Text="{Binding RoomCode}"
                         FontFamily="Consolas"
                         FontSize="13"
                         Foreground="#FF6EC7" />
              <TextBlock Text="{Binding TracksPlayed.Count, StringFormat='Tracks: {0}'}"
                         FontSize="11"
                         Foreground="#666" />
            </StackPanel>
            <StackPanel Grid.Column="1" Spacing="2" HorizontalAlignment="Right">
              <TextBlock Text="{Binding PeakListeners, StringFormat='Peak: {0}'}"
                         FontSize="11"
                         Foreground="#888" />
              <TextBlock Text="{Binding StartedAt, StringFormat='{}{0:MMM d}'}"
                         FontSize="10"
                         Foreground="#555" />
            </StackPanel>
          </Grid>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

  </Grid>
</UserControl>
