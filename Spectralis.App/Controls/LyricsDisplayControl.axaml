<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Spectralis.App.ViewModels"
             x:Class="Spectralis.App.Controls.LyricsDisplayControl"
             Background="#0D0D0D">

  <Grid RowDefinitions="*, Auto">

    <!-- Main lyrics display -->
    <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center"
                Spacing="12" Margin="24">

      <!-- Current line with word highlight -->
      <TextBlock x:Name="CurrentLineBlock"
                 Text="{Binding CurrentLineText}"
                 FontSize="22"
                 FontWeight="SemiBold"
                 Foreground="White"
                 TextAlignment="Center"
                 TextWrapping="Wrap" />

      <!-- Word highlight (enhanced LRC) -->
      <TextBlock x:Name="CurrentWordBlock"
                 Text="{Binding CurrentWordText}"
                 FontSize="16"
                 Foreground="#FF6EC7"
                 TextAlignment="Center"
                 IsVisible="{Binding CurrentWordText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

      <!-- No lyrics placeholder -->
      <TextBlock Text="No lyrics available"
                 FontSize="14"
                 Foreground="#555555"
                 TextAlignment="Center"
                 IsVisible="{Binding !HasLyrics}" />
    </StackPanel>

    <!-- Annotation panel -->
    <Border Grid.Row="1"
            Background="#1A1A2E"
            BorderBrush="#2A2A4E"
            BorderThickness="0,1,0,0"
            Padding="16,12"
            IsVisible="{Binding ShowAnnotation}">
      <Grid ColumnDefinitions="*, Auto">
        <StackPanel Grid.Column="0" Spacing="4">
          <TextBlock Text="Annotation"
                     FontSize="10"
                     Foreground="#888"
                     FontWeight="SemiBold"
                     TextTransform="Uppercase"
                     LetterSpacing="1" />
          <TextBlock Text="{Binding CurrentAnnotation.Explanation}"
                     FontSize="13"
                     Foreground="#CCCCCC"
                     TextWrapping="Wrap" />
        </StackPanel>
        <Button Grid.Column="1"
                Content="✕"
                Command="{Binding RemoveAnnotationCommand}"
                VerticalAlignment="Top"
                Background="Transparent"
                Foreground="#666"
                Padding="8,4" />
      </Grid>
    </Border>

  </Grid>
</UserControl>
