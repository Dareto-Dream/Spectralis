<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Spectralis.App.ViewModels"
             xmlns:ctrl="using:Spectralis.App.Controls"
             x:Class="Spectralis.App.Controls.BeatGridView"
             x:DataType="vm:BpmViewModel"
             Background="#0A0A14">

  <Grid RowDefinitions="Auto,Auto,*">

    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="20" Margin="12,8">
      <StackPanel>
        <TextBlock Text="BPM" FontSize="10" Foreground="#555577"/>
        <TextBlock Text="{Binding Bpm, StringFormat='{}{0:F1}'}"
                   FontSize="20" FontWeight="Bold" Foreground="White"/>
      </StackPanel>
      <StackPanel>
        <TextBlock Text="KEY" FontSize="10" Foreground="#555577"/>
        <TextBlock Text="{Binding Key}" FontSize="20" FontWeight="Bold" Foreground="#9B8EFF"/>
      </StackPanel>
      <StackPanel>
        <TextBlock Text="LUFS" FontSize="10" Foreground="#555577"/>
        <TextBlock Text="{Binding LoudnessLufs, StringFormat='{}{0:F1} dB'}"
                   FontSize="13" Foreground="#8888AA" VerticalAlignment="Center"/>
      </StackPanel>
    </StackPanel>

    <ProgressBar Grid.Row="1" IsVisible="{Binding IsAnalyzing}"
                 IsIndeterminate="True" Height="2"/>

    <Border Grid.Row="2" Margin="12,4" Background="#0E0E1A" CornerRadius="4">
      <TextBlock Text="{Binding StatusMessage}" Foreground="#555577"
                 FontSize="11" Margin="8,6"
                 IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
    </Border>

  </Grid>
</UserControl>
