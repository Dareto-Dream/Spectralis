<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Spectralis.App.Controls.CapsuleV5Dialog"
        Title="Open Capsule"
        Width="560" Height="480"
        Background="#0D0D0D">

  <Grid RowDefinitions="Auto, *, Auto">

    <!-- Header -->
    <Border Grid.Row="0" Background="#111" Padding="20,16">
      <StackPanel Spacing="4">
        <TextBlock x:Name="TitleText" Text="Capsule" FontSize="20" FontWeight="SemiBold" Foreground="White" />
        <TextBlock x:Name="ArtistText" Text="" FontSize="13" Foreground="#888" />
        <TextBlock x:Name="VerifiedText" Text="" FontSize="11" Foreground="#4CAF50" />
      </StackPanel>
    </Border>

    <!-- Track list -->
    <ListBox Grid.Row="1"
             x:Name="TrackList"
             Background="#0A0A0A"
             BorderThickness="0">
      <ListBox.ItemTemplate>
        <DataTemplate>
          <Grid ColumnDefinitions="32, *, Auto" Margin="12,8">
            <TextBlock Grid.Column="0"
                       Text="{Binding Order}"
                       Foreground="#555"
                       FontFamily="Consolas"
                       VerticalAlignment="Center" />
            <StackPanel Grid.Column="1" Spacing="2">
              <TextBlock Text="{Binding Title}" FontSize="13" Foreground="White" />
              <TextBlock Text="{Binding Artist}" FontSize="11" Foreground="#666" />
            </StackPanel>
            <TextBlock Grid.Column="2"
                       Text="🔒"
                       IsVisible="{Binding IsLocked}"
                       VerticalAlignment="Center"
                       Margin="8,0" />
          </Grid>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

    <!-- Footer -->
    <Border Grid.Row="2" Background="#111" Padding="16">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
        <Button Content="Cancel" Click="OnCancel" Background="#222" Foreground="White" Padding="16,8" />
        <Button Content="Open World" Click="OnOpen" Background="#2A2A6E" Foreground="White" Padding="16,8" />
      </StackPanel>
    </Border>

  </Grid>
</Window>
