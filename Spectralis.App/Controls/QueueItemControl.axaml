<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:queue="clr-namespace:Spectralis.Core.Queue;assembly=Spectralis.Core"
             x:Class="Spectralis.App.Controls.QueueItemControl">
  <Grid ColumnDefinitions="Auto,*,Auto,Auto" Background="Transparent">
    <Border Grid.Column="0" Width="4" Cursor="SizeNS"
            Background="Transparent" VerticalAlignment="Stretch"
            PointerPressed="OnDragHandlePressed"
            PointerMoved="OnDragHandleMoved"
            PointerReleased="OnDragHandleReleased">
      <TextBlock Text="⠿" VerticalAlignment="Center" Opacity="0.4" FontSize="14" Margin="4,0"/>
    </Border>

    <StackPanel Grid.Column="1" Margin="6,4" VerticalAlignment="Center">
      <TextBlock Text="{Binding Track.Title}" FontSize="13" TextTrimming="CharacterEllipsis"/>
      <TextBlock Text="{Binding Track.Artist}" FontSize="11" Opacity="0.6" TextTrimming="CharacterEllipsis"/>
    </StackPanel>

    <TextBlock Grid.Column="2" Text="{Binding Track.Duration, StringFormat='{}{0:mm\\:ss}'}"
               FontSize="11" Opacity="0.5" VerticalAlignment="Center" Margin="8,0"/>

    <Button Grid.Column="3" Content="✕" Width="24" Height="24"
            Background="Transparent" BorderThickness="0"
            VerticalAlignment="Center" Margin="2,0"
            Click="OnRemoveClick" Opacity="0.4"/>
  </Grid>
</UserControl>
