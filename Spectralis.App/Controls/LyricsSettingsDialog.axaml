<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Spectralis.App.Controls.LyricsSettingsDialog"
        Title="Lyrics Settings"
        Width="400" Height="340"
        Background="#111111"
        CanResize="False">

  <StackPanel Margin="24" Spacing="16">

    <CheckBox Content="Enable lyrics" IsChecked="{Binding Enabled}" Foreground="White" />
    <CheckBox Content="Show annotations" IsChecked="{Binding ShowAnnotations}" Foreground="White" />
    <CheckBox Content="Word highlight (Enhanced LRC)" IsChecked="{Binding ShowWordHighlight}" Foreground="White" />

    <Grid ColumnDefinitions="*, 16, 120" RowDefinitions="Auto, 12, Auto">
      <TextBlock Grid.Row="0" Grid.Column="0" Text="Font size" Foreground="#999" VerticalAlignment="Center" />
      <NumericUpDown Grid.Row="0" Grid.Column="2"
                     Value="{Binding FontSize}"
                     Minimum="10" Maximum="48" Increment="1"
                     Background="#1A1A1A" Foreground="White" />

      <TextBlock Grid.Row="2" Grid.Column="0" Text="Sync offset (ms)" Foreground="#999" VerticalAlignment="Center" />
      <NumericUpDown Grid.Row="2" Grid.Column="2"
                     Value="{Binding SyncOffsetMs}"
                     Minimum="-5000" Maximum="5000" Increment="50"
                     Background="#1A1A1A" Foreground="White" />
    </Grid>

    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,16,0,0">
      <Button Content="Cancel" Click="OnCancel" Background="#222" Foreground="White" Padding="16,8" />
      <Button Content="Save" Click="OnSave" Background="#2A4A2A" Foreground="White" Padding="16,8" />
    </StackPanel>

  </StackPanel>
</Window>
