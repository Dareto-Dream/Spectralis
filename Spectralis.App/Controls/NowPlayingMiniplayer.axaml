<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Spectralis.App.Controls.NowPlayingMiniplayer"
             Background="#0D0D0D"
             Width="320">

  <Border Background="#111" CornerRadius="12" Padding="12">
    <Grid ColumnDefinitions="64, 12, *">

      <!-- Cover art -->
      <Border Grid.Column="0"
              Width="64" Height="64"
              CornerRadius="6"
              ClipToBounds="True"
              Background="#222">
        <Image x:Name="CoverImage" Stretch="UniformToFill" />
      </Border>

      <!-- Track info + controls -->
      <StackPanel Grid.Column="2" Spacing="4" VerticalAlignment="Center">
        <TextBlock x:Name="TitleText"
                   Text="—"
                   FontSize="13"
                   FontWeight="SemiBold"
                   Foreground="White"
                   TextTrimming="CharacterEllipsis" />
        <TextBlock x:Name="ArtistText"
                   Text=""
                   FontSize="11"
                   Foreground="#888"
                   TextTrimming="CharacterEllipsis" />

        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
          <Button x:Name="PrevButton" Content="⏮" Background="Transparent"
                  Foreground="#CCC" Padding="4" FontSize="14" />
          <Button x:Name="PlayPauseButton" Content="▶" Background="Transparent"
                  Foreground="White" Padding="4" FontSize="16" FontWeight="Bold" />
          <Button x:Name="NextButton" Content="⏭" Background="Transparent"
                  Foreground="#CCC" Padding="4" FontSize="14" />
        </StackPanel>
      </StackPanel>

    </Grid>
  </Border>
</UserControl>
