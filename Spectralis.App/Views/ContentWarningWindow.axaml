<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Spectralis.App.Views.ContentWarningWindow"
        Title="Content Warning"
        Width="420" Height="280"
        MinWidth="360" MinHeight="220"
        WindowStartupLocation="CenterOwner"
        SystemDecorations="BorderOnly"
        Background="{StaticResource Brush.Bg.Base}"
        KeyDown="OnKeyDown">

  <Grid RowDefinitions="Auto,*,Auto" Margin="28,24,28,20">

    <!-- Header -->
    <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,16">
      <TextBlock Text="Content Warning" Classes="heading" />
      <TextBlock x:Name="TrackNameLabel"
                 Classes="secondary"
                 FontSize="{StaticResource FontSize.UI.Small}"
                 TextTrimming="CharacterEllipsis" />
    </StackPanel>

    <!-- Tag chips -->
    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
      <ItemsControl x:Name="TagsPanel">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <WrapPanel Orientation="Horizontal" />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Background="{StaticResource Brush.Bg.Raised}"
                    BorderBrush="{StaticResource Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="3"
                    Padding="10,4"
                    Margin="0,0,6,6">
              <TextBlock Text="{Binding}"
                         Classes="secondary"
                         FontSize="{StaticResource FontSize.UI.Small}" />
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

    <!-- Buttons -->
    <StackPanel Grid.Row="2"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="8"
                Margin="0,16,0,0">
      <Button Content="Play Anyway" Click="OnPlayAnyway" Classes="primary" />
      <Button Classes="ghost" Content="Cancel" Click="OnCancel" />
    </StackPanel>

  </Grid>
</Window>
