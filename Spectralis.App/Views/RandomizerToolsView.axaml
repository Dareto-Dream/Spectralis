<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Spectralis.App.ViewModels"
             x:Class="Spectralis.App.Views.RandomizerToolsView"
             x:DataType="vm:RandomizerToolsViewModel">

  <Grid RowDefinitions="Auto,*">

    <!-- Header -->
    <Border Grid.Row="0" Background="{StaticResource Brush.Bg.Raised}" Padding="24,14">
      <StackPanel Spacing="2">
        <TextBlock Classes="heading" Text="Randomizer Tools" />
        <TextBlock Classes="secondary" Text="Stream tools: coin flip, spin wheel, and more" />
      </StackPanel>
    </Border>

    <!-- Body -->
    <Grid Grid.Row="1" ColumnDefinitions="*,Auto">

      <!-- Wheel area fills all available space -->
      <Grid Grid.Column="0" RowDefinitions="*,Auto">
        <Canvas Name="WheelCanvas" Grid.Row="0"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" Spacing="8" Margin="0,12,0,20">
          <TextBlock Text="{Binding WheelResult}"
                     HorizontalAlignment="Center"
                     FontSize="18" FontWeight="SemiBold"
                     IsVisible="{Binding HasWheelResult}" />
          <Button Content="Spin!" Command="{Binding SpinCommand}"
                  Classes="primary" HorizontalAlignment="Center" />
        </StackPanel>
      </Grid>

      <!-- Sidebar: coin toss + entries -->
      <Border Grid.Column="1" Width="260"
              Background="{StaticResource Brush.Bg.Raised}"
              BorderBrush="{StaticResource Brush.Border}" BorderThickness="1,0,0,0"
              Padding="16">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto">

          <!-- Coin toss -->
          <TextBlock Grid.Row="0" Classes="heading" Text="Coin Toss" Margin="0,0,0,12" />
          <StackPanel Grid.Row="1" Spacing="10" HorizontalAlignment="Center" Margin="0,0,0,16">
            <Border Name="CoinVisual" Width="80" Height="80" CornerRadius="40"
                    Background="{StaticResource Brush.Signal}" HorizontalAlignment="Center">
              <TextBlock Name="CoinFaceLabel" Text="?"
                         HorizontalAlignment="Center" VerticalAlignment="Center"
                         FontSize="24" FontWeight="Bold"
                         Foreground="{StaticResource Brush.Bg.Base}" />
            </Border>
            <TextBlock Text="{Binding CoinResult}"
                       HorizontalAlignment="Center"
                       FontSize="14" FontWeight="SemiBold"
                       IsVisible="{Binding CoinResult, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
            <Button Content="Flip Coin" Command="{Binding FlipCoinCommand}"
                    Classes="primary" HorizontalAlignment="Center" />
          </StackPanel>

          <Separator Grid.Row="2" Margin="0,0,0,12" />

          <!-- Entries header -->
          <TextBlock Grid.Row="3" Classes="secondary"
                     Text="WHEEL ENTRIES" FontWeight="SemiBold"
                     Margin="0,0,0,8" />

          <!-- Entries list -->
          <ListBox Grid.Row="4"
                   ItemsSource="{Binding WheelEntries}"
                   Background="Transparent"
                   SelectionMode="Single">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Grid ColumnDefinitions="*,Auto" Margin="0,1,0,1">
                  <TextBlock Grid.Column="0" Text="{Binding}"
                             VerticalAlignment="Center"
                             TextTrimming="CharacterEllipsis" />
                  <Button Grid.Column="1" Content="×"
                          Click="OnRemoveEntryClick"
                          Classes="ghost"
                          Padding="6,2" FontSize="14"
                          ToolTip.Tip="Remove" />
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <!-- Add entry -->
          <Grid Grid.Row="5" ColumnDefinitions="*,Auto" Margin="0,8,0,0">
            <TextBox Grid.Column="0"
                     Text="{Binding NewEntryText}"
                     Watermark="New entry..."
                     Margin="0,0,6,0"
                     KeyDown="OnNewEntryKeyDown" />
            <Button Grid.Column="1" Content="Add"
                    Command="{Binding AddEntryCommand}" />
          </Grid>

        </Grid>
      </Border>

    </Grid>
  </Grid>

</UserControl>
