<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Spectralis.App.ViewModels"
             x:Class="Spectralis.App.Views.RandomizerToolsView"
             x:DataType="vm:RandomizerToolsViewModel">

  <Grid RowDefinitions="Auto,*">

    <!-- Header -->
    <Border Grid.Row="0" Background="{StaticResource Brush.Bg.Raised}" Padding="24,14">
      <StackPanel Spacing="2">
        <TextBlock Classes="heading" Text="Randomizer Tools" />
        <TextBlock Classes="secondary" Text="Stream tools: coin flip, spin wheel, and more" />
      </StackPanel>
    </Border>

    <!-- Content -->
    <ScrollViewer Grid.Row="1">
      <Grid ColumnDefinitions="260,*" Margin="16">

        <!-- Coin Toss card -->
        <Border Grid.Column="0"
                Background="{StaticResource Brush.Bg.Raised}"
                BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
                Padding="20" Margin="0,0,8,0">
          <StackPanel Spacing="16" HorizontalAlignment="Center">
            <TextBlock Classes="heading" Text="Coin Toss" HorizontalAlignment="Center" />

            <Border Name="CoinVisual" Width="120" Height="120" CornerRadius="60"
                    Background="{StaticResource Brush.Signal}" HorizontalAlignment="Center">
              <TextBlock Name="CoinFaceLabel" Text="?"
                         HorizontalAlignment="Center" VerticalAlignment="Center"
                         FontSize="36" FontWeight="Bold"
                         Foreground="{StaticResource Brush.Bg.Base}" />
            </Border>

            <TextBlock Text="{Binding CoinResult}"
                       HorizontalAlignment="Center"
                       FontSize="18" FontWeight="SemiBold"
                       IsVisible="{Binding CoinResult, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

            <Button Content="Flip Coin" Command="{Binding FlipCoinCommand}"
                    Classes="primary" HorizontalAlignment="Center" />
          </StackPanel>
        </Border>

        <!-- Spin Wheel card -->
        <Border Grid.Column="1"
                Background="{StaticResource Brush.Bg.Raised}"
                BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
                Padding="20" Margin="8,0,0,0">
          <Grid RowDefinitions="Auto,*">
            <TextBlock Grid.Row="0" Classes="heading" Text="Spin Wheel" Margin="0,0,0,12" />

            <Grid Grid.Row="1" ColumnDefinitions="*,Auto">

              <!-- Wheel canvas + result + spin button -->
              <StackPanel Grid.Column="0" Spacing="12" HorizontalAlignment="Center"
                          VerticalAlignment="Top">
                <Canvas Name="WheelCanvas" Width="220" Height="220"
                        HorizontalAlignment="Center" />
                <TextBlock Text="{Binding WheelResult}"
                           HorizontalAlignment="Center"
                           FontSize="16" FontWeight="SemiBold"
                           IsVisible="{Binding HasWheelResult}" />
                <Button Content="Spin!" Command="{Binding SpinCommand}"
                        Classes="primary" HorizontalAlignment="Center" />
              </StackPanel>

              <!-- Entry management -->
              <Border Grid.Column="1" Width="240" Margin="16,0,0,0"
                      BorderBrush="{StaticResource Brush.Border}"
                      BorderThickness="1,0,0,0" Padding="16,0,0,0">
                <Grid RowDefinitions="Auto,*,Auto">
                  <TextBlock Grid.Row="0" Classes="secondary"
                             Text="ENTRIES" FontWeight="SemiBold"
                             Margin="0,0,0,8" />

                  <ListBox Grid.Row="1"
                           ItemsSource="{Binding WheelEntries}"
                           Background="Transparent"
                           SelectionMode="Single">
                    <ListBox.ItemTemplate>
                      <DataTemplate>
                        <Grid ColumnDefinitions="*,Auto" Margin="0,1,0,1">
                          <TextBlock Grid.Column="0" Text="{Binding}"
                                     VerticalAlignment="Center"
                                     TextTrimming="CharacterEllipsis" />
                          <Button Grid.Column="1" Content="×"
                                  Click="OnRemoveEntryClick"
                                  Classes="ghost"
                                  Padding="6,2" FontSize="14"
                                  ToolTip.Tip="Remove" />
                        </Grid>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>

                  <Grid Grid.Row="2" ColumnDefinitions="*,Auto"
                        Margin="0,8,0,0">
                    <TextBox Grid.Column="0"
                             Text="{Binding NewEntryText}"
                             Watermark="New entry..."
                             Margin="0,0,6,0"
                             KeyDown="OnNewEntryKeyDown" />
                    <Button Grid.Column="1" Content="Add"
                            Command="{Binding AddEntryCommand}" />
                  </Grid>
                </Grid>
              </Border>

            </Grid>
          </Grid>
        </Border>

      </Grid>
    </ScrollViewer>
  </Grid>

</UserControl>
