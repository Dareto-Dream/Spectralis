<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Spectralis.App.Views.LyricsAnnotationEditorWindow"
        Title="Edit Annotations"
        Width="820" Height="540"
        MinWidth="560" MinHeight="360"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        KeyDown="OnKeyDown"
        Background="{StaticResource Brush.Bg.Base}">

  <Grid RowDefinitions="Auto,*,Auto">

    <!-- Header -->
    <StackPanel Grid.Row="0" Margin="24,18,24,14" Spacing="4">
      <TextBlock x:Name="TrackTitleLabel"
                 Classes="heading"
                 FontSize="{StaticResource FontSize.UI.Large}"
                 TextTrimming="CharacterEllipsis" />
      <TextBlock x:Name="SubtitleLabel"
                 Classes="secondary"
                 FontSize="{StaticResource FontSize.UI.Small}" />
    </StackPanel>

    <!-- Content: left line list + right annotation editor -->
    <Grid Grid.Row="1" ColumnDefinitions="*,340" Margin="12,0,12,0">

      <!-- Left: lyrics lines -->
      <Border Grid.Column="0"
              Background="{StaticResource Brush.Bg.Raised}"
              BorderBrush="{StaticResource Brush.Border}"
              BorderThickness="1"
              Margin="0,0,6,0">
        <ScrollViewer x:Name="LyricsScroll" Padding="8">
          <ScrollViewer.Styles>
            <Style Selector="Border.annot-row">
              <Setter Property="Padding" Value="10,7,10,7" />
              <Setter Property="Margin" Value="0,0,0,2" />
              <Setter Property="Cursor" Value="Hand" />
            </Style>
            <Style Selector="Border.annot-row.selected">
              <Setter Property="Background" Value="{StaticResource Brush.Bg.Overlay}" />
              <Setter Property="BorderBrush" Value="{StaticResource Brush.Signal}" />
              <Setter Property="BorderThickness" Value="2,0,0,0" />
            </Style>
            <Style Selector="Border.annot-row.has-note">
              <Setter Property="BorderBrush" Value="{StaticResource Brush.Signal}" />
              <Setter Property="BorderThickness" Value="2,0,0,0" />
            </Style>
          </ScrollViewer.Styles>
          <!-- Rows injected from code-behind -->
        </ScrollViewer>
      </Border>

      <!-- Right: annotation text editor -->
      <Border Grid.Column="1"
              Background="{StaticResource Brush.Bg.Raised}"
              BorderBrush="{StaticResource Brush.Border}"
              BorderThickness="1"
              Padding="16,14,16,16">
        <Grid RowDefinitions="Auto,Auto,*">
          <TextBlock Grid.Row="0"
                     Text="ANNOTATION"
                     FontSize="10"
                     FontWeight="Bold"
                     LetterSpacing="1.5"
                     Foreground="{StaticResource Brush.Signal}"
                     Margin="0,0,0,10" />
          <TextBlock Grid.Row="1"
                     x:Name="SelectedLineLabel"
                     TextWrapping="Wrap"
                     FontWeight="SemiBold"
                     Text="Select a line to edit its annotation."
                     Margin="0,0,0,10"
                     Classes="secondary" />
          <TextBox Grid.Row="2"
                   x:Name="AnnotationTextBox"
                   AcceptsReturn="True"
                   TextWrapping="Wrap"
                   Watermark="Type an annotation for this lyric line..."
                   IsEnabled="False"
                   VerticalAlignment="Stretch"
                   VerticalContentAlignment="Top"
                   TextChanged="OnAnnotationTextChanged" />
        </Grid>
      </Border>

    </Grid>

    <!-- Footer -->
    <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto" Margin="12,10,12,14">
      <TextBlock Grid.Column="0"
                 x:Name="StatusLabel"
                 Classes="secondary"
                 VerticalAlignment="Center"
                 FontSize="{StaticResource FontSize.UI.Small}" />
      <Button Grid.Column="1" Content="Save" Click="OnSave"
              Classes="primary" Margin="0,0,8,0" />
      <Button Grid.Column="2" Content="Close" Click="OnClose" />
    </Grid>

  </Grid>
</Window>
