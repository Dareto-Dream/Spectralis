<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Spectralis.App.ViewModels"
             x:Class="Spectralis.App.Views.SharedPlayView"
             x:DataType="vm:SharedPlayViewModel">

  <ScrollViewer>
    <StackPanel Margin="24" Spacing="12" MaxWidth="560">

      <TextBlock Classes="display" Text="Shared Play" />
      <TextBlock Classes="secondary"
                 Text="Host a room so others can follow along in their browser in sync." />

      <TextBlock Classes="data" Text="{Binding StatusText}" />

      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button Content="Host Room" Command="{Binding HostCommand}" Classes="primary" IsVisible="{Binding !IsHosting}" />
        <Button Content="Stop Hosting" Command="{Binding StopCommand}" Classes="destructive" IsVisible="{Binding IsHosting}" />
        <Button Content="Copy Link" Command="{Binding CopyLinkCommand}" IsVisible="{Binding IsHosting}" />
      </StackPanel>

      <StackPanel IsVisible="{Binding IsHosting}" Spacing="4">
        <TextBlock Classes="secondary" Text="Join URL" />
        <TextBox Text="{Binding JoinUrl}" IsReadOnly="True" />
      </StackPanel>

      <TextBlock Classes="error" Text="{Binding LastError}"
                 IsVisible="{Binding LastError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

      <!-- ─── Streamer Queue ─────────────────────────────────────────────── -->

      <StackPanel IsVisible="{Binding IsHosting}" Spacing="0" Margin="0,8,0,0">

        <!-- section divider -->
        <Border Height="1" Background="{StaticResource Brush.Border}" Margin="0,0,0,12" />

        <!-- header row -->
        <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,4">
          <TextBlock Classes="heading" Text="Streamer Queue" VerticalAlignment="Center" />
          <CheckBox Grid.Column="1" Content="Enable" IsChecked="{Binding SqEnabled}" />
        </Grid>
        <TextBlock Classes="secondary" Margin="0,0,0,10"
                   Text="Let viewers request tracks, skip, and pay via your own Stripe account." />

        <!-- body: shown only when enabled -->
        <StackPanel IsVisible="{Binding SqEnabled}" Spacing="10">

          <!-- Submit URL -->
          <StackPanel Spacing="4">
            <TextBlock Classes="secondary" Text="Submit URL (share with viewers)" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
              <TextBox Text="{Binding SqSubmitUrl}" IsReadOnly="True" />
              <Button Grid.Column="1" Content="Copy" Command="{Binding SqCopySubmitUrlCommand}" />
            </Grid>
          </StackPanel>

          <!-- General options -->
          <CheckBox Content="Require manual approval before tracks enter the queue"
                    IsChecked="{Binding SqRequireApproval}" />
          <CheckBox Content="Allow duplicate track submissions"
                    IsChecked="{Binding SqAllowDuplicates}" />
          <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <TextBlock Classes="secondary" VerticalAlignment="Center" Text="Max queue length" />
            <TextBox Text="{Binding SqMaxQueueLength}" Width="64" />
          </StackPanel>

          <!-- divider -->
          <Border Height="1" Background="{StaticResource Brush.Border}" Margin="0,4,0,4" />

          <!-- Queue Entry Fee -->
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock VerticalAlignment="Center" Text="Queue Entry Fee" />
            <CheckBox Grid.Column="1" Content="Enable" IsChecked="{Binding SqQueueFeeEnabled}" />
          </Grid>
          <StackPanel IsVisible="{Binding SqQueueFeeEnabled}" Spacing="4" Margin="0,-4,0,0">
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
              <TextBlock Classes="secondary" VerticalAlignment="Center" Text="$" />
              <TextBox Text="{Binding SqQueueFeeAmount}" Width="80"
                       Watermark="5.00" />
              <TextBlock Classes="muted" VerticalAlignment="Center" Text="USD" />
            </StackPanel>
          </StackPanel>

          <!-- Skip Requests -->
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock VerticalAlignment="Center" Text="Skip Requests" />
            <CheckBox Grid.Column="1" Content="Enable" IsChecked="{Binding SqSkipEnabled}" />
          </Grid>
          <StackPanel IsVisible="{Binding SqSkipEnabled}" Spacing="4" Margin="0,-4,0,0">
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
              <TextBlock Classes="secondary" VerticalAlignment="Center" Text="$" />
              <TextBox Text="{Binding SqSkipAmount}" Width="80" Watermark="2.00" />
              <TextBlock Classes="muted" VerticalAlignment="Center" Text="USD (0 = free)" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
              <TextBlock Classes="secondary" VerticalAlignment="Center" Text="Votes to trigger" />
              <TextBox Text="{Binding SqSkipVotes}" Width="50" Watermark="3" />
            </StackPanel>
          </StackPanel>

          <!-- Super Skips -->
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock VerticalAlignment="Center" Text="⚡ Super Skip" />
            <CheckBox Grid.Column="1" Content="Enable" IsChecked="{Binding SqSuperSkipEnabled}" />
          </Grid>
          <StackPanel IsVisible="{Binding SqSuperSkipEnabled}" Spacing="4" Margin="0,-4,0,0">
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
              <TextBlock Classes="secondary" VerticalAlignment="Center" Text="$" />
              <TextBox Text="{Binding SqSuperSkipAmount}" Width="80" Watermark="10.00" />
              <TextBlock Classes="muted" VerticalAlignment="Center" Text="USD (0 = free)" />
            </StackPanel>
          </StackPanel>

          <!-- divider -->
          <Border Height="1" Background="{StaticResource Brush.Border}" Margin="0,4,0,4"
                  IsVisible="{Binding SqAnyFeeEnabled}" />

          <!-- Stripe Connect (only when at least one fee is enabled) -->
          <StackPanel IsVisible="{Binding SqAnyFeeEnabled}" Spacing="8">
            <!-- Not connected -->
            <StackPanel IsVisible="{Binding !SqStripeConnected}" Spacing="6">
              <TextBlock Classes="error"
                         Text="⚠  Connect a Stripe account to collect payments." />
              <Button Content="Connect Stripe →"
                      Command="{Binding SqConnectStripeCommand}"
                      Classes="primary" HorizontalAlignment="Left" />
            </StackPanel>
            <!-- Connected -->
            <StackPanel IsVisible="{Binding SqStripeConnected}"
                        Orientation="Horizontal" Spacing="8">
              <TextBlock Classes="secondary" VerticalAlignment="Center"
                         Text="{Binding SqStripeStatus}" />
              <Button Content="Disconnect" Classes="ghost"
                      Command="{Binding SqDisconnectStripeCommand}" />
            </StackPanel>
          </StackPanel>

          <!-- divider before save -->
          <Border Height="1" Background="{StaticResource Brush.Border}" Margin="0,4,0,4" />

          <!-- Status text -->
          <TextBlock Classes="data" Text="{Binding SqStatus}"
                     IsVisible="{Binding SqStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

          <!-- Save button -->
          <Button Content="Save Settings" Command="{Binding SqSaveCommand}"
                  Classes="primary" HorizontalAlignment="Left" />

          <!-- Pending approvals (shown when requireApproval is on and items exist) -->
          <StackPanel IsVisible="{Binding SqHasPending}" Spacing="6" Margin="0,8,0,0">
            <Border Height="1" Background="{StaticResource Brush.Border}" />
            <TextBlock Classes="heading" Text="{Binding SqPendingHeaderText}" />
            <ItemsControl ItemsSource="{Binding SqPendingItems}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:SqPendingItemVm">
                  <Border Margin="0,0,0,4" Padding="10,8"
                          Background="{StaticResource Brush.Bg.Raised}"
                          BorderBrush="{StaticResource Brush.Border}"
                          BorderThickness="1">
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                      <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                        <TextBlock Classes="muted" Text="{Binding Url}"
                                   TextTrimming="CharacterEllipsis" />
                      </StackPanel>
                      <Button Grid.Column="1" Content="Approve"
                              Classes="primary"
                              Command="{Binding ApproveCommand}" />
                      <Button Grid.Column="2" Content="Reject"
                              Classes="destructive"
                              Command="{Binding RejectCommand}" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>

        </StackPanel>
      </StackPanel>

    </StackPanel>
  </ScrollViewer>

</UserControl>
