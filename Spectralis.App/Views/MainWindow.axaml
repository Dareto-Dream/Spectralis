<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Spectralis.App.Views.MainWindow"
        Title="Spectralis"
        Width="1200"
        Height="780"
        MinWidth="800"
        MinHeight="520"
        Background="#0E0E14">
    <Grid RowDefinitions="Auto,*,Auto,72">
        <TextBlock Grid.Row="0"
                   Text="Spectralis"
                   Foreground="#8080FF"
                   FontSize="11"
                   Margin="12,6"
                   Opacity="0.6" />
        <Border Grid.Row="1"
                Background="#121218"
                Margin="0"
                Name="ContentHost">
            <TextBlock Text="Loading…"
                       Foreground="#40404A"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="14" />
        </Border>
        <Border Grid.Row="2"
                Background="#0A0A10"
                Height="4" />
        <Border Grid.Row="3"
                Background="#0E0E14"
                Name="NowPlayingHost" />
    </Grid>
</Window>
