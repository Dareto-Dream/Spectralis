<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Spectralis.App.ViewModels"
        xmlns:views="using:Spectralis.App.Views"
        xmlns:ctrl="using:Spectralis.App.Controls"
        x:Class="Spectralis.App.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="Spectralis"
        Width="1200" Height="780"
        MinWidth="800" MinHeight="520"
        Background="#0E0E14">

  <Grid RowDefinitions="32,*,4,80">

    <!-- Header bar -->
    <Border Grid.Row="0" Background="#0A0A12">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
        <TextBlock Grid.Column="0" Text="SPECTRALIS" Foreground="#7B68EE"
                   FontSize="11" FontWeight="Bold" Margin="12,0,0,0"
                   VerticalAlignment="Center" LetterSpacing="2"/>
        <ctrl:WaveformView Grid.Column="1" Height="28" Margin="16,2"
                           Name="HeaderWaveform"/>
        <Button Grid.Column="2" Content="Library" FontSize="11" Padding="8,4"
                Background="Transparent" Foreground="#AAAAAA"
                Command="{Binding ToggleLibraryCommand}"/>
        <Button Grid.Column="3" Content="Queue" FontSize="11" Padding="8,4"
                Background="Transparent" Foreground="#AAAAAA"
                Command="{Binding ToggleQueueCommand}"/>
        <Button Grid.Column="4" Content="&#x2699;" FontSize="14" Padding="8,4"
                Background="Transparent" Foreground="#AAAAAA"
                ToolTip.Tip="Settings"/>
      </Grid>
    </Border>

    <!-- Content area: Library | Main | Queue -->
    <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto">

      <!-- Library panel -->
      <Border Grid.Column="0" Width="280"
              IsVisible="{Binding IsLibraryVisible}"
              BorderBrush="#22223A" BorderThickness="0,0,1,0">
        <views:LibraryView DataContext="{Binding Library}"/>
      </Border>

      <!-- Center: Visualizer + status -->
      <Grid Grid.Column="1" RowDefinitions="*,Auto">
        <ctrl:SpectrumBarsControl Grid.Row="0" Name="SpectrumViz"
                                  Background="#0E0E14"/>
        <Border Grid.Row="1" Background="#111120" Padding="12,4">
          <TextBlock Text="{Binding StatusMessage}" FontSize="11"
                     Foreground="#666688"/>
        </Border>
      </Grid>

      <!-- Queue panel -->
      <Border Grid.Column="2" Width="280"
              IsVisible="{Binding IsQueueVisible}"
              BorderBrush="#22223A" BorderThickness="1,0,0,0">
        <views:QueueView DataContext="{Binding Queue}"/>
      </Border>

    </Grid>

    <!-- Divider -->
    <Border Grid.Row="2" Background="#22223A"/>

    <!-- Now playing bar -->
    <views:NowPlayingView Grid.Row="3" DataContext="{Binding Player}"/>

  </Grid>
</Window>
