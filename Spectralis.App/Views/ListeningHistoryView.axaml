<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Spectralis.App.ViewModels"
             x:Class="Spectralis.App.Views.ListeningHistoryView"
             x:DataType="vm:ListeningHistoryViewModel"
             Background="#0C0C16">

  <Grid RowDefinitions="Auto,*,Auto">

    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="10,8">
      <TextBox Grid.Column="0" Text="{Binding FilterQuery}"
               Watermark="Filter by title or artist…"/>
      <Button Grid.Column="1" Content="Clear" Command="{Binding ClearCommand}"
              Margin="8,0,0,0" Background="#3A1A1A" Foreground="#CC6666"/>
    </Grid>

    <ListBox Grid.Row="1" ItemsSource="{Binding Entries}"
             Background="Transparent">
      <ListBox.ItemTemplate>
        <DataTemplate>
          <Grid ColumnDefinitions="*,Auto" Margin="10,4">
            <StackPanel Grid.Column="0">
              <TextBlock Text="{Binding Title}" Foreground="White" FontSize="13"/>
              <TextBlock Text="{Binding Artist}" Foreground="#888899" FontSize="11"/>
            </StackPanel>
            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
              <TextBlock Text="{Binding PlayedAtDisplay}" Foreground="#555577" FontSize="10"/>
              <TextBlock Text="✓" Foreground="#4CAF50" FontSize="10" HorizontalAlignment="Right"
                         IsVisible="{Binding WasSubmitted}"/>
            </StackPanel>
          </Grid>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

    <ProgressBar Grid.Row="2" IsVisible="{Binding IsLoading}"
                 IsIndeterminate="True" Height="2"/>

  </Grid>
</UserControl>
