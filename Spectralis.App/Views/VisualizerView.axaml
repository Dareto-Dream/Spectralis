<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Spectralis.App.ViewModels"
             xmlns:ctrl="using:Spectralis.App.Controls"
             x:Class="Spectralis.App.Views.VisualizerView"
             x:DataType="vm:VisualizerViewModel"
             Background="#0E0E14">

  <Grid ColumnDefinitions="*,200">

    <ctrl:VisualizerCanvas Grid.Column="0" Name="Canvas"/>

    <Border Grid.Column="1" BorderBrush="#22223A" BorderThickness="1,0,0,0">
      <ctrl:VisualizerPickerControl DataContext="{Binding}"/>
    </Border>

  </Grid>
</UserControl>
