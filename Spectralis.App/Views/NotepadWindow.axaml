<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Spectralis.App.ViewModels"
        x:Class="Spectralis.App.Views.NotepadWindow"
        x:DataType="vm:NotepadViewModel"
        Title="{Binding Title}"
        Icon="/Assets/icon.png"
        Width="380" Height="420"
        MinWidth="240" MinHeight="200"
        Background="{StaticResource Brush.Bg.Base}">

  <Grid RowDefinitions="Auto,*,Auto" Margin="14">
    <TextBox Grid.Row="0" Text="{Binding Title}" FontWeight="SemiBold" Margin="0,0,0,8" />
    <TextBox Grid.Row="1" Text="{Binding Content}"
             AcceptsReturn="True" TextWrapping="Wrap"
             VerticalContentAlignment="Top" />
    <TextBlock Grid.Row="2" Classes="muted" FontSize="{StaticResource FontSize.UI.Small}"
               Margin="0,8,0,0"
               Text="Edits here stay in sync with the docked notepad — use Save to Track there to embed."
               TextWrapping="Wrap" />
  </Grid>

</Window>
