<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Spectralis.App.Views.VideoExportWindow"
        Title="Export Video"
        Width="540" Height="420"
        MinWidth="440" MinHeight="360"
        WindowStartupLocation="CenterOwner"
        SystemDecorations="BorderOnly"
        Background="{StaticResource Brush.Bg.Base}"
        KeyDown="OnKeyDown">

  <Grid RowDefinitions="Auto,*,Auto" Margin="28,24,28,20">

    <!-- Header -->
    <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,20">
      <TextBlock Text="Export Video" Classes="heading" />
      <TextBlock x:Name="TrackLabel"
                 Classes="secondary"
                 FontSize="{StaticResource FontSize.UI.Small}"
                 TextTrimming="CharacterEllipsis" />
    </StackPanel>

    <!-- Body -->
    <StackPanel Grid.Row="1" Spacing="14">

      <!-- Output path -->
      <StackPanel Spacing="6">
        <TextBlock Text="Output File" Classes="secondary" FontSize="{StaticResource FontSize.UI.Small}" />
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
          <TextBox x:Name="OutputPathBox"
                   Grid.Column="0"
                   Watermark="Choose output file…"
                   IsReadOnly="True" />
          <Button Grid.Column="1"
                  Content="Browse…"
                  Click="OnBrowse" />
        </Grid>
      </StackPanel>

      <!-- Options row -->
      <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
        <StackPanel Grid.Column="0" Spacing="6">
          <TextBlock Text="Resolution" Classes="secondary" FontSize="{StaticResource FontSize.UI.Small}" />
          <ComboBox x:Name="ResolutionBox" HorizontalAlignment="Stretch" />
        </StackPanel>
        <StackPanel Grid.Column="1" Spacing="6">
          <TextBlock Text="Frame Rate" Classes="secondary" FontSize="{StaticResource FontSize.UI.Small}" />
          <ComboBox x:Name="FpsBox" HorizontalAlignment="Stretch" />
        </StackPanel>
        <StackPanel Grid.Column="2" Spacing="6">
          <TextBlock Text="Visualizer" Classes="secondary" FontSize="{StaticResource FontSize.UI.Small}" />
          <ComboBox x:Name="ModeBox" HorizontalAlignment="Stretch" />
        </StackPanel>
      </Grid>

      <!-- Progress area -->
      <StackPanel Spacing="8" Margin="0,4,0,0">
        <ProgressBar x:Name="ExportProgress"
                     Minimum="0" Maximum="100"
                     Height="5"
                     IsVisible="False" />
        <TextBlock x:Name="StatusLabel"
                   Classes="secondary"
                   FontSize="{StaticResource FontSize.UI.Small}"
                   TextWrapping="Wrap"
                   IsVisible="False" />
      </StackPanel>

    </StackPanel>

    <!-- Buttons -->
    <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8" Margin="0,16,0,0">
      <TextBlock Grid.Column="0"
                 x:Name="FfmpegHintLabel"
                 Classes="muted"
                 FontSize="{StaticResource FontSize.UI.Small}"
                 Text="Requires FFmpeg in the app folder or PATH."
                 VerticalAlignment="Center"
                 TextWrapping="Wrap" />
      <Button Grid.Column="1"
              x:Name="ExportButton"
              Content="Export"
              Click="OnExport"
              Classes="primary" />
      <Button Grid.Column="2"
              x:Name="CloseButton"
              Classes="ghost"
              Content="Close"
              Click="OnClose" />
    </Grid>

  </Grid>
</Window>
