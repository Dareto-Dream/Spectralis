<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Spectralis.App.ViewModels"
        x:Class="Spectralis.App.Views.TagEditorDialog"
        x:DataType="vm:TagEditorViewModel"
        Title="Edit Tags"
        Width="480" Height="420"
        Background="#12121C"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

  <Grid RowDefinitions="*,Auto" Margin="16">

    <Grid Grid.Row="0" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="120,*" RowDefinitions2="32" Margin="0,0,0,8">

      <TextBlock Grid.Row="0" Grid.Column="0" Text="Title" VerticalAlignment="Center" Foreground="#AAAAAA" FontSize="13"/>
      <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Title}" Background="#0E0E18" Foreground="White" BorderBrush="#333355" Margin="0,2"/>

      <TextBlock Grid.Row="1" Grid.Column="0" Text="Artist" VerticalAlignment="Center" Foreground="#AAAAAA" FontSize="13"/>
      <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Artist}" Background="#0E0E18" Foreground="White" BorderBrush="#333355" Margin="0,2"/>

      <TextBlock Grid.Row="2" Grid.Column="0" Text="Album Artist" VerticalAlignment="Center" Foreground="#AAAAAA" FontSize="13"/>
      <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding AlbumArtist}" Background="#0E0E18" Foreground="White" BorderBrush="#333355" Margin="0,2"/>

      <TextBlock Grid.Row="3" Grid.Column="0" Text="Album" VerticalAlignment="Center" Foreground="#AAAAAA" FontSize="13"/>
      <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Album}" Background="#0E0E18" Foreground="White" BorderBrush="#333355" Margin="0,2"/>

      <TextBlock Grid.Row="4" Grid.Column="0" Text="Genre" VerticalAlignment="Center" Foreground="#AAAAAA" FontSize="13"/>
      <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Genre}" Background="#0E0E18" Foreground="White" BorderBrush="#333355" Margin="0,2"/>

      <TextBlock Grid.Row="5" Grid.Column="0" Text="Year" VerticalAlignment="Center" Foreground="#AAAAAA" FontSize="13"/>
      <NumericUpDown Grid.Row="5" Grid.Column="1" Value="{Binding Year}"
                     Minimum="0" Maximum="9999" FormatString="0"
                     Background="#0E0E18" Foreground="White" Margin="0,2"/>

      <TextBlock Grid.Row="6" Grid.Column="0" Text="Track #" VerticalAlignment="Center" Foreground="#AAAAAA" FontSize="13"/>
      <NumericUpDown Grid.Row="6" Grid.Column="1" Value="{Binding TrackNumber}"
                     Minimum="0" Maximum="999" FormatString="0"
                     Background="#0E0E18" Foreground="White" Margin="0,2"/>

      <TextBlock Grid.Row="7" Grid.Column="0" Text="Disc #" VerticalAlignment="Center" Foreground="#AAAAAA" FontSize="13"/>
      <NumericUpDown Grid.Row="7" Grid.Column="1" Value="{Binding DiscNumber}"
                     Minimum="0" Maximum="99" FormatString="0"
                     Background="#0E0E18" Foreground="White" Margin="0,2"/>

    </Grid>

    <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto">
      <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" VerticalAlignment="Center"
                 Foreground="#888888" FontSize="11"/>
      <Button Grid.Column="1" Content="Save" Command="{Binding SaveCommand}"
              IsEnabled="{Binding IsDirty}" Margin="0,0,8,0"
              Background="#3D3D5C" Foreground="White" Padding="12,6"/>
      <Button Grid.Column="2" Content="Close" Click="OnCloseClick"
              Background="Transparent" Foreground="#AAAAAA" Padding="12,6"/>
    </Grid>

  </Grid>
</Window>
