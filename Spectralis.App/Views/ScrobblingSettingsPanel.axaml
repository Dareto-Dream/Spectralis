<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Spectralis.App.ViewModels"
             x:Class="Spectralis.App.Views.ScrobblingSettingsPanel"
             x:DataType="vm:ScrobblingStatusViewModel"
             Background="#0C0C16">

  <StackPanel Margin="16,12" Spacing="12">

    <TextBlock Text="Scrobbling" FontSize="15" FontWeight="SemiBold" Foreground="White"/>

    <ToggleButton Content="{Binding IsEnabled, Converter={StaticResource BoolToEnabledConverter}}"
                  IsChecked="{Binding IsEnabled}"
                  Command="{Binding ToggleCommand}"
                  HorizontalAlignment="Left"/>

    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" Margin="0,8">
      <TextBlock Grid.Row="0" Grid.Column="0" Text="Last.fm:" Foreground="#888899" FontSize="12" Margin="0,0,16,4"/>
      <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding LastFmStatus}" Foreground="White" FontSize="12"/>
      <TextBlock Grid.Row="1" Grid.Column="0" Text="ListenBrainz:" Foreground="#888899" FontSize="12" Margin="0,0,16,0"/>
      <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ListenBrainzStatus}" Foreground="White" FontSize="12"/>
    </Grid>

    <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding PendingCount, Converter={StaticResource NotZeroConverter}}">
      <TextBlock Text="{Binding PendingCount, StringFormat='{}{0} pending scrobbles'}"
                 Foreground="#CCAA44" FontSize="11" VerticalAlignment="Center"/>
      <Button Content="Flush Now" Command="{Binding FlushPendingCommand}"
              Background="#2A2A3A" Foreground="#CCAA44" Padding="10,4" FontSize="11"/>
    </StackPanel>

  </StackPanel>
</UserControl>
