<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Spectralis.App.ViewModels"
             x:Class="Spectralis.App.Views.CapsuleView"
             x:DataType="vm:CapsuleViewModel"
             Background="#0A0A16">

  <Grid RowDefinitions="Auto,*,Auto">

    <StackPanel Grid.Row="0" Margin="12,10" Spacing="2"
                IsVisible="{Binding IsLoaded}">
      <TextBlock Text="{Binding CapsuleTitle}" FontSize="18"
                 FontWeight="SemiBold" Foreground="White"/>
      <TextBlock Text="{Binding CapsuleArtist}" FontSize="13"
                 Foreground="#8888AA"/>
    </StackPanel>

    <Grid Grid.Row="0" IsVisible="{Binding IsLoading}">
      <TextBlock Text="Loading capsule…" Foreground="#555577"
                 HorizontalAlignment="Center" VerticalAlignment="Center"
                 Margin="12,20"/>
    </Grid>

    <ListBox Grid.Row="1" ItemsSource="{Binding Tracks}"
             SelectedItem="{Binding SelectedTrack}"
             Background="Transparent">
      <ListBox.ItemTemplate>
        <DataTemplate>
          <Grid ColumnDefinitions="28,*,Auto" Margin="10,5">
            <TextBlock Grid.Column="0" Text="{Binding Id}"
                       Foreground="#555577" FontSize="11" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0">
              <TextBlock Text="{Binding Title}" Foreground="White" FontSize="13"/>
              <TextBlock Text="{Binding Artist}" Foreground="#666688" FontSize="11"/>
            </StackPanel>
          </Grid>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

    <TextBlock Grid.Row="2" Text="{Binding ErrorMessage}"
               Foreground="#CC4444" Margin="12,6" FontSize="11"
               IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
  </Grid>
</UserControl>
